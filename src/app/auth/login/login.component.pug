section.hero.is-fullheight
  .hero-body
    .container
      .columns
        .column
        .column.is-narrow.box
          .container.p-3
            p.title.has-text-centered WISdoM OSS
            form(#f="ngForm" "(ngSubmit)"="onSubmit(f)" noValidate)
              .field
                label.label {{"core.login.username" | translate}}
                .control.has-icons-left.has-icons-right
                  input.input(
                    [class.is-success]="f.value.username"
                    type="text"
                    name="username"
                    placeholder="{{'core.login.username' | translate}}"
                    required
                    ngModel
                  )
                  span.icon.is-left
                    ion-icon(name="id-card")
                  span.icon.is-right
                    ion-icon(
                      [class.is-invisible]="!f.value.username"
                      name="checkmark"
                    )
              .field
                label.label {{"core.login.password" | translate}}
                .control.has-icons-left.has-icons-right
                  input.input(
                    [class.is-danger]="loginHasIssue"
                    type="password"
                    name="password"
                    placeholder="{{'core.login.password' | translate}}"
                    required
                    ngModel
                    #passwordInput
                  )
                  span.icon.is-left
                    ion-icon(name="key")
                  span.icon.is-right
                    ion-icon(
                      [class.is-invisible]="!loginHasIssue"
                      name="warning"
                      )
              .content.m-0
                a {{"core.login.forgotPassword" | translate}}
              p.has-text-centered.has-text-danger.is-centered.m-1(
                [class.is-invisible]="!loginHasIssue"
              ) {{loginHasIssue}}
              .field
                p.control
                  button.button.is-success.is-fullwidth(
                    type="submit"
                  ) {{"core.login.login" | translate}}
        .column
